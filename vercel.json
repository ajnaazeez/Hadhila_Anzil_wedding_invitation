{
  "version": 2,
  "public": true,
  "buildCommand": "echo 'Static site, no build needed'",
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/music.mpeg",
      "dest": "/music.mpeg",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable",
        "content-type": "audio/mpeg"
      }
    },
    {
      "src": "/hadi.jpeg",
      "dest": "/hadi.jpeg",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
